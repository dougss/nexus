#!/usr/bin/env node
// Nexus MCP server — stdio transport (JSON-RPC 2.0)
// For local Claude Code use. Remote clients: use nexus-mcp-http (HTTP/SSE).

import { createInterface } from "node:readline";
import { handle, rpcError } from "./nexus-core.js";

const rl = createInterface({ input: process.stdin, terminal: false });

rl.on("line", (line) => {
  const trimmed = line.trim();
  if (!trimmed) return;
  let req;
  try {
    req = JSON.parse(trimmed);
  } catch {
    process.stdout.write(
      JSON.stringify(rpcError(null, -32700, "Parse error")) + "\n",
    );
    return;
  }
  const res = handle(req);
  if (res !== null) {
    process.stdout.write(JSON.stringify(res) + "\n");
  }
});

rl.on("close", () => process.exit(0));
