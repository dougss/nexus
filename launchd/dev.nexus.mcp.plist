    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/macmini/server/logs/nexus-mcp.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/macmini/server/logs/nexus-mcp.log</string>
